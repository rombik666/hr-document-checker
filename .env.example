PROJECT_NAME=HR Document Checker
APP_ENV=local
DEBUG=true

DATABASE_URL=sqlite:///./data/app.db

POSTGRES_DB=hr_doc_checker
POSTGRES_USER=hr_user
POSTGRES_PASSWORD=hr_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

LOG_DIR=logs
LOG_FILE=app.log

RAG_RETRIEVER_TYPE=faiss
RAG_EMBEDDING_BACKEND=sentence_transformer
RAG_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBEDDING_DIMENSION=384
RAG_INDEX_DIR=data/index
RAG_ALLOW_EMBEDDING_FALLBACK=true
HF_HOME=data/hf_cache

LLM_PROVIDER=mock
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60
LLM_ENABLED=true