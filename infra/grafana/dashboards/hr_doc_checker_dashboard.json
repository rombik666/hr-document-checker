{
  "uid": "hr-doc-checker-overview",
  "title": "HR Document Checker Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "Requests total",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "requests_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Documents processed",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "documents_processed_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Reports generated",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "reports_generated_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Errors total",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "errors_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Issues found",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "issues_found_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Average request time, ms",
      "gridPos": { "x": 8, "y": 4, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "average_request_time_ms",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Average document processing time, ms",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "average_document_processing_time_ms",
          "refId": "A"
        }
      ]
    }
  ]
}